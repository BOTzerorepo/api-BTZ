{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.0.2",
        "ext-gd": "*",
        "barryvdh/laravel-dompdf": "^1.0",
        "darkaonline/l5-swagger": "^8.3",
        "doctrine/dbal": "^4.1",
        "google/apiclient": "^2.18",
        "guzzlehttp/guzzle": "^7.9",
        "irazasyed/larasupport": "^1.1",
        "laravel/framework": "^9.11",
        "laravel/passport": "^10.4",
        "laravel/sanctum": "^2.14.1",
        "laravel/tinker": "^2.7",
        "maatwebsite/excel": "^3.1",
        "owen-it/laravel-auditing": "^13.6",
        "psr/simple-cache": "^2.0",

        "spatie/laravel-permission": "^6.25",

        "sentry/sentry-laravel": "^4.25",

        "tymon/jwt-auth": "^2.2"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "modules/",
            "Controllers\\":"controllers/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "audit": {
            "abandoned": "ignore",
            "ignore": {
                "PKSA-qstp-ffwg-8hp6": "dompdf known XSS — sandbox-only deployment",
                "PKSA-5vz3-q51h-7mg4": "dompdf known issue — sandbox-only deployment",
                "PKSA-7ztm-rpt3-qqzk": "dompdf known issue — sandbox-only deployment",
                "PKSA-4jrs-y99s-q8j6": "dompdf known issue — sandbox-only deployment",
                "PKSA-hbk6-2vfz-8f8n": "dompdf known issue — sandbox-only deployment",
                "PKSA-kj9c-tr41-t8mj": "dompdf known issue — sandbox-only deployment",
                "PKSA-872h-8556-2chm": "dompdf known issue — sandbox-only deployment",
                "PKSA-99tj-gg5v-4g74": "dompdf known issue — sandbox-only deployment"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
